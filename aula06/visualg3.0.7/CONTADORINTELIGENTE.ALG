Algoritmo "contadorinteligente"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 8/10/2025
Var
   // Seçăo de Declaraçőes das variáveis
   contador,constante,n:real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   contador<-10
   constante<-0
   repita
      escreval("escreva um numero:")
      leia(n)
      se(n=1) entao
         enquanto (constante<=10)faca
            escreva(constante)
            constante<-constante+1
         fimenquanto
      fimse
      se(n=2)entao
         enquanto (contador>=0)faca
            escreva(contador)
            contador<-contador-1
         fimenquanto
         se(n=3)entao
         fimse
      fimse
   ate(n=3)




Fimalgoritmo
