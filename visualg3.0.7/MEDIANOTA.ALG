Algoritmo "medianota"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 03/08/2025
Var
   // Seçăo de Declaraçőes das variáveis
   q,cons,media,nota,menor:real
   nome:caractere
Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   cons<-1
   nota<-0
   menor<-10
   escreval("quantos aluno a sala tem:")
   leia(q)
   enquanto (cons<=q)faca
      escreval("nome do aluno:")
      leia(nome)
      escreval("qual a media do aluno:")
      leia(media)
      cons<-cons+1
      se(media>nota)entao
         nota<-media
         se(nota<menor)entao
            menor<-nota
         fimse
      fimse
   fimenquanto
   escreval("A MELHOR NOTA FOI DE ", NOME , " COM MEDIA",NOTA)




Fimalgoritmo